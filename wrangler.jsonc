{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "box-rd-frontend",
  "compatibility_date": "2026-07-21",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist/admin-box-RD/browser",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
